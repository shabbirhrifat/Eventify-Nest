NODE_ENV=development
APP_NAME=competition-registration-system
PORT=3000
GLOBAL_PREFIX=api

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=competition_registration
DB_SYNCHRONIZE=true
DB_LOGGING=false

JWT_SECRET=change-this-to-a-long-random-secret-with-at-least-32-characters
JWT_REFRESH_SECRET=change-this-refresh-secret-to-a-long-random-secret-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

UPLOADS_ROOT_PATH=uploads

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

SMTP_HOST=log
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Competition Registration System
SMTP_FROM_EMAIL=no-reply@example.com

IDEMPOTENCY_TTL_HOURS=24
EMAIL_QUEUE_ATTEMPTS=3
REGISTRATION_QUEUE_ATTEMPTS=5


# Current
NODE_ENV=development
APP_NAME=nestjs-blueprint
PORT=3000
